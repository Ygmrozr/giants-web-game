<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <title>Attack on Titan Map Menu</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      width:100vw;
      height:100vh;
      overflow:hidden;
    }

    .map-container{
      position:relative;
      width:100vw;
      height:100vh;
      background:url("/images/map-menu.png") no-repeat center center;
      background-size:cover;
    }

    .panel{
      position:absolute;
      background:rgba(0,0,0,0.6);
      color:white;
      padding:15px;
      border-radius:12px;
    }

    .welcome-panel{
      top:20px;
      left:20px;
      width:260px;
    }

    .title-panel{
      top:20px;
      right:20px;
      text-align:right;
      min-width:200px;
    }

    .level{
      font-size:18px;
      font-weight:bold;
      margin-bottom:8px;
    }

    .progress-bar{
      width:100%;
      height:10px;
      background:rgba(255,255,255,0.2);
      border-radius:6px;
      overflow:hidden;
      margin-bottom:6px;
    }

    .progress{
      height:100%;
      background:#00d8ff;
      transition:width 0.4s;
    }

    .score-text{
      font-size:12px;
      opacity:0.8;
    }

    .hotspot{
      position:absolute;
      text-decoration:none;
    }

    .label{
      color:white;
      font-weight:bold;
      text-shadow:0 2px 6px rgba(0,0,0,0.8);
    }

  </style>
</head>

<body>

<%
  const safeProgress = isNaN(progress) ? 0 : progress;
  const progressPercent = Math.max(0, Math.min(100, safeProgress * 100)).toFixed(2);
%>

<div class="map-container">

  <!-- SOL ÜST PANEL -->
  <div class="panel welcome-panel">

    <div style="font-weight:bold; margin-bottom:8px;">
      Welcome, <%= user.username %>
    </div>

    <div class="level">
      Level: <%= level %>
    </div>

    <div class="progress-bar">
      <div class="progress" style="width:<%= progressPercent %>%"></div>
    </div>

    <div class="score-text">
      <%= user.totalScore %> / <%= nextLevel %>
    </div>

  </div>

  <!-- SAĞ ÜST -->
  <div class="panel title-panel">
    <div>Current Title</div>
    <div style="font-size:18px; font-weight:bold;">
      <%= user.title %>
    </div>
  </div>

  <!-- LEVEL UP -->
  <% if(titleUnlocked){ %>
    <div style="
      position:absolute;
      top:120px;
      left:20px;
      background:rgba(0,216,255,0.3);
      padding:10px 15px;
      border-radius:10px;
      color:white;
      font-weight:bold;
    ">
      🎉 <%= titleUnlocked %>
    </div>
  <% } %>

  <!-- HOTSPOTS -->

  <a class="hotspot" href="/game" style="left:30%; top:70%;">
    <span class="label">Start Game</span>
  </a>

  <a class="hotspot" href="/leaderboard" style="left:45%; top:36%;">
    <span class="label">Leaderboard</span>
  </a>

  <a class="hotspot" href="/profile" style="left:60%; top:28%;">
    <span class="label">My Profile</span>
  </a>

  <a class="hotspot" href="/account" style="left:53%; top:52%;">
    <span class="label">My Account</span>
  </a>

  <a class="hotspot" href="/how-to-play" style="left:44%; top:61%;">
    <span class="label">How to Play</span>
  </a>

  <a class="hotspot" href="/market" style="left:72%; top:40%;">
    <span class="label">Market</span>
  </a>

  <a class="hotspot" href="/titles" style="left:50%; top:22%;">
    <span class="label">Titles</span>
  </a>

  <a class="hotspot" href="/logout" style="left:85%; top:83%;">
    <span class="label">Logout</span>
  </a>

</div>

</body>
</html>