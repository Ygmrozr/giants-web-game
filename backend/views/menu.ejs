<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <title>Main Menu</title>
  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      width:100vw;
      height:100vh;
      overflow:hidden;
      background:#111;
    }

    .menu-container{
      position:relative;
      width:100vw;
      height:100vh;
      background:url("/images/map-menu.png") no-repeat center center;
      background-size:cover;
    }

    .panel{
      position:absolute;
      background:rgba(0,0,0,0.62);
      color:white;
      padding:16px 18px;
      border-radius:14px;
      box-shadow:0 10px 30px rgba(0,0,0,0.35);
      backdrop-filter:blur(2px);
    }

    .left-info{
      top:20px;
      left:20px;
      width:290px;
    }

    .title-panel{
      top:20px;
      right:20px;
      min-width:220px;
      text-align:right;
    }

    .right-menu{
      top:50%;
      right:40px;
      transform:translateY(-50%);
      width:270px;
    }

    .welcome{
      font-size:18px;
      font-weight:bold;
      margin-bottom:10px;
    }

    .level{
      font-size:18px;
      font-weight:bold;
      margin-bottom:8px;
    }

    .progress-bar{
      width:100%;
      height:12px;
      background:rgba(255,255,255,0.2);
      border-radius:999px;
      overflow:hidden;
      margin-bottom:8px;
    }

    .progress{
      height:100%;
      background:linear-gradient(90deg, #00d8ff, #4facfe);
      transition:width 0.4s ease;
    }

    .score-text{
      font-size:13px;
      opacity:0.9;
    }

    .title-label{
      font-size:14px;
      opacity:0.9;
      margin-bottom:6px;
    }

    .title-name{
      font-size:20px;
      font-weight:bold;
      color:#8fefff;
    }

    .unlock-panel{
      position:absolute;
      top:160px;
      left:20px;
      background:rgba(0,216,255,0.24);
      color:white;
      padding:12px 16px;
      border-radius:12px;
      font-weight:bold;
      box-shadow:0 8px 22px rgba(0,0,0,0.25);
    }

    .levelup-panel{
      position:absolute;
      top:220px;
      left:20px;
      background:rgba(76,175,80,0.24);
      color:white;
      padding:12px 16px;
      border-radius:12px;
      font-weight:bold;
      box-shadow:0 8px 22px rgba(0,0,0,0.25);
    }

    .right-menu h2{
      margin-bottom:18px;
      text-align:center;
      font-size:24px;
    }

    .menu-link{
      display:block;
      text-decoration:none;
      color:white;
      font-weight:bold;
      background:rgba(255,255,255,0.08);
      padding:14px 16px;
      border-radius:10px;
      margin-bottom:12px;
      transition:0.25s ease;
      text-align:center;
    }

    .menu-link:hover{
      background:rgba(0,216,255,0.2);
      transform:translateX(-4px);
    }
  </style>
</head>
<body>

<%
  const safeProgress = isNaN(progress) ? 0 : progress;
  const progressPercent = Math.max(0, Math.min(100, safeProgress * 100)).toFixed(2);
%>

<div class="menu-container">

  <!-- SOL ÜST -->
  <div class="panel left-info">
    <div class="welcome">
      Welcome, <%= user.username %>
    </div>

    <div class="level">
      Level: <%= level %>
    </div>

    <div class="progress-bar">
      <div class="progress" style="width:<%= progressPercent %>%;"></div>
    </div>

    <div class="score-text">
      <%= user.totalScore %> / <%= nextLevel %> score
    </div>
  </div>

  <!-- SAĞ ÜST TITLE -->
  <div class="panel title-panel">
    <div class="title-label">Current Title</div>
    <div class="title-name"><%= user.title %></div>
  </div>

  <!-- ÜNVAN BİLDİRİMİ -->
  <% if(titleUnlocked){ %>
    <div class="unlock-panel">
      🎉 <%= titleUnlocked %>
    </div>
  <% } %>

  <!-- LEVEL UP BİLDİRİMİ -->
  <% if(levelUp){ %>
    <div class="levelup-panel">
      ⭐ <%= levelUp %>
    </div>
  <% } %>

  <!-- SAĞ ORTA MENÜ -->
  <div class="panel right-menu">
    <h2>Main Menu</h2>

    <a class="menu-link" href="/map">Start Game</a>
    <a class="menu-link" href="/profile">My Profile</a>
    <a class="menu-link" href="/account">My Account</a>
    <a class="menu-link" href="/leaderboard">Leaderboard</a>
    <a class="menu-link" href="/market">Market</a>
    <a class="menu-link" href="/how-to-play">How to Play</a>
    <a class="menu-link" href="/titles">Titles</a>
    <a class="menu-link" href="/logout">Logout</a>
  </div>

</div>

</body>
</html>